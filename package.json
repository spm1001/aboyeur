{
  "name": "aboyeur",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "npm run test:daemon && npm run test:channel",
    "test:daemon": "tsc && node --test $(find dist -name '*.test.js' ! -name 'conductor-channel.test.js' ! -name 'conductor-bridge-supersede.test.js' ! -name 'mesh-id-seam.test.js' ! -name 'send-confirm.test.js' ! -name 'deregister-timing.test.js')",
    "test:channel": "bun test src/conductor-channel.test.ts src/conductor-bridge-supersede.test.ts src/mesh-id-seam.test.ts src/send-confirm.test.ts src/deregister-timing.test.ts",
    "channel:bun": "bun src/conductor-channel.ts"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "typescript": "^5.7"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2"
  }
}
